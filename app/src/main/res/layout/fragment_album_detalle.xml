<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2FAF8"
    android:padding="16dp">

    <!-- ================= HEADER ================= -->

    <!-- Etiqueta -->
    <TextView
        android:id="@+id/txtLabelNombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre del álbum:"
        android:textSize="13sp"
        android:textColor="#607D8B"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Nombre protagonista -->
    <TextView
        android:id="@+id/txtNombreAlbum"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Cactus colección 2026"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#004D40"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/txtLabelNombre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnEditarNombre"
        app:layout_constraintHorizontal_bias="0"/>

    <!-- Botón editar como acción lateral -->
    <com.google.android.material.chip.Chip
        android:id="@+id/btnEditarNombre"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Editar"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:textColor="@color/teal_primary"
        app:backgroundTint="@android:color/transparent"
        app:strokeColor="@color/teal_primary"
        app:strokeWidth="1dp"
        app:cornerRadius="18dp"
        app:layout_constraintBaseline_toBaselineOf="@id/txtNombreAlbum"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Estado como badge -->
    <com.google.android.material.chip.Chip
        android:id="@+id/txtEstadoAlbum"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="12sp"
        android:checkable="false"
        app:chipCornerRadius="20dp"
        app:chipMinHeight="36dp"
        app:chipIconVisible="true"
        app:chipIconTint="@android:color/white"
        app:rippleColor="#22000000"
        app:layout_constraintEnd_toEndOf="@+id/view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtNombreAlbum" />

    <!-- Divider elegante -->
    <View
        android:id="@+id/view"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#E0E0E0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtEstadoAlbum" />

    <!-- ================= GRID PLANTAS ================= -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPlantasAlbum"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtEstadoAlbum"
        app:layout_constraintBottom_toTopOf="@id/layoutBotones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= BOTONES ================= -->

    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditarAlbum"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Agregar más plantas"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/teal_primary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPublicarAlbum"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Publicar álbum"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:layout_marginTop="10dp"
            app:cornerRadius="14dp"
            app:backgroundTint="#4CAF50"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
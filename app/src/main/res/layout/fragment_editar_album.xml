<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2FAF8"
    android:padding="16dp">

    <!-- =========================
         HEADER
         ========================= -->

    <TextView
        android:id="@+id/txtTituloEditar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Editar álbum"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#004D40"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtNombreAlbum"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nombre del álbum"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#00695C"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/txtTituloEditar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtEstadoAlbum"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BORRADOR"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:background="@drawable/bg_estado_borrador"
        android:textColor="@android:color/black"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtNombreAlbum"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Divider -->
    <View
        android:id="@+id/dividerTop"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#B2DFDB"
        app:layout_constraintTop_toBottomOf="@id/txtEstadoAlbum"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- =========================
         LISTA DE PLANTAS
         ========================= -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPlantasAlbum"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/dividerTop"
        app:layout_constraintBottom_toTopOf="@id/layoutBotones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- =========================
         BOTONES INFERIORES
         ========================= -->

    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BOTÓN PRINCIPAL -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAgregarPlantas"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Agregar nueva planta"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/teal_primary"/>

        <!-- BOTÓN SECUNDARIO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolverDetalle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Volver"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginTop="10dp"
            app:cornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/teal_primary"
            android:textColor="@color/teal_primary"
            app:backgroundTint="@android:color/transparent"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
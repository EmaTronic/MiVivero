<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="96dp"
    android:padding="8dp">

    <!-- FOTO PRINCIPAL -->
    <ImageView
        android:id="@+id/imgPlanta"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_planta_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- NUMERO DE PLANTA -->
    <TextView
        android:id="@+id/txtNumeroPlanta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="001"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@android:color/black"
        app:layout_constraintStart_toEndOf="@id/imgPlanta"
        app:layout_constraintTop_toTopOf="@id/imgPlanta"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="12dp"/>

    <!-- FAMILIA / ESPECIE -->
    <TextView
        android:id="@+id/txtFamiliaEspecie"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Fabaceae - Acacia"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/txtNumeroPlanta"
        app:layout_constraintTop_toBottomOf="@id/txtNumeroPlanta"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CANTIDAD -->
    <TextView
        android:id="@+id/txtCantidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="x3"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="@id/txtNumeroPlanta"
        app:layout_constraintTop_toBottomOf="@id/txtFamiliaEspecie"/>

    <!-- A LA VENTA -->
    <TextView
        android:id="@+id/txtVenta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A la venta"
        android:textSize="12sp"
        android:textColor="@android:color/holo_green_dark"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/imgPlanta"/>

</androidx.constraintlayout.widget.ConstraintLayout>

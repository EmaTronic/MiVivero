<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/listaPlantasFragment"

    >


    <action
        android:id="@+id/action_global_verificarEmailFragment"
        app:destination="@id/verificarEmailFragment" />




    <fragment
        android:id="@+id/identificarFragment"
        android:name="com.emanuel.mivivero.ui.identificar.IdentificarFragment"
        android:label="Identificar" />



    <!-- 🌱 MENÚ PRINCIPAL
    <fragment
        android:id="@+id/viveroFragment"
        android:name="com.emanuel.mivivero.ui.vivero.ViveroFragment"
        android:label="Vivero">

        <action
            android:id="@+id/action_viveroFragment_to_listaPlantasFragment"
            app:destination="@id/listaPlantasFragment" />

        <action
            android:id="@+id/action_viveroFragment_to_crearAlbumesFragment"
            app:destination="@id/crearAlbumesFragment" />

        <action
            android:id="@+id/action_viveroFragment_to_albumesFragment"
            app:destination="@id/albumesFragment" />
    </fragment>

    -->

    <!-- 🌿 PLANTAS -->
    <fragment
        android:id="@+id/crearPlantaFragment"
        android:name="com.emanuel.mivivero.ui.vivero.CrearPlantaFragment"
        android:label="Crear / Editar Planta">

        <argument
            android:name="plantaId"
            app:argType="long"
            android:defaultValue="-1L" />
    </fragment>

    <fragment
        android:id="@+id/listaPlantasFragment"
        android:name="com.emanuel.mivivero.ui.vivero.ListaPlantasFragment"
        android:label="Plantas" />

    <fragment
        android:id="@+id/plantaDetalleFragment"
        android:name="com.emanuel.mivivero.ui.viviero.PlantaDetalleFragment"
        android:label="Detalle Planta" />

    <fragment
        android:id="@+id/compararFotosFragment"
        android:name="com.emanuel.mivivero.ui.vivero.CompararFotosFragment"
        android:label="Comparar fotos" />

    <!-- 📚 ÁLBUMES -->
    <fragment
        android:id="@+id/crearAlbumesFragment"
        android:name="com.emanuel.mivivero.ui.albumes.CrearAlbumesFragment"
        android:label="Crear álbum">

        <action
            android:id="@+id/action_crearAlbumesFragment_to_editarAlbumFragment"
            app:destination="@id/editarAlbumFragment" />

    </fragment>

    <fragment
        android:id="@+id/editarAlbumFragment"
        android:name="com.emanuel.mivivero.ui.albumes.EditarAlbumFragment"
        android:label="Editar álbum">

        <argument
            android:name="albumId"
            app:argType="long" />



        <action
            android:id="@+id/action_editarAlbumFragment_to_listaPlantasFragment"
            app:destination="@id/listaPlantasFragment" />
    </fragment>

    <fragment
        android:id="@+id/albumDetalleFragment"
        android:name="com.emanuel.mivivero.ui.albumes.AlbumDetalleFragment"
        android:label="Detalle del álbum">

        <argument
            android:name="albumId"
            app:argType="long" />




        <action
            android:id="@+id/action_albumDetalleFragment_to_editarAlbumFragment"
            app:destination="@id/editarAlbumFragment" />

    </fragment>





    <fragment
        android:id="@+id/albumesFragment"
        android:name="com.emanuel.mivivero.ui.albumes.AlbumesFragment"
        android:label="Álbumes">

        <action
            android:id="@+id/action_albumesFragment_to_crearAlbumesFragment"
            app:destination="@id/crearAlbumesFragment" />

        <action
            android:id="@+id/action_albumesFragment_to_albumDetalleFragment"
            app:destination="@id/albumDetalleFragment" />

    </fragment>


    <fragment
        android:id="@+id/authFragment"
        android:name="com.emanuel.mivivero.ui.auth.AuthFragment"
        android:label="Autenticación" />


    <fragment
        android:id="@+id/registroUsuarioFragment"
        android:name="com.emanuel.mivivero.ui.auth.RegistroUsuarioFragment"
        android:label="Registro Usuario" />

    <fragment
        android:id="@+id/comunidadFragment"
        android:name="com.emanuel.mivivero.ui.comunidad.ComunidadFragment"
        android:label="Comunidad" />


    <!-- NAVEGACIÓN A DETALLE_PUBLICACION-->
    <fragment
        android:id="@+id/detallePublicacionFragment"
        android:name="com.emanuel.mivivero.ui.comunidad.DetallePublicacionFragment"
        android:label="Detalle Publicación">

        <argument
            android:name="publicacionId"
            app:argType="string" />
    </fragment>


    <fragment
        android:id="@+id/albumComunidadFragment"
        android:name="com.emanuel.mivivero.ui.comunidad.AlbumComunidadFragment"
        android:label="Álbum Comunidad">

        <argument
            android:name="albumId"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.emanuel.mivivero.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login" />



    <fragment
        android:id="@+id/sesionCerradaFragment"
        android:name="com.emanuel.mivivero.ui.auth.SesionCerradaFragment"
        android:label="Sesión cerrada"/>




    <fragment
        android:id="@+id/verificarEmailFragment"
        android:name="com.emanuel.mivivero.ui.auth.VerificarEmailFragment"
        android:label="Verificar Email"/>

    <fragment
        android:id="@+id/notificacionesFragment"
        android:name="com.emanuel.mivivero.ui.notificaciones.NotificacionesFragment"
        android:label="Notificaciones"/>



</navigation>
